---
import { DEFAULT_PLATFORM, platformOptions } from "./configurator-data";
import { COPY_SVG } from '../lib/shiki-config.js';

interface Props {
    copyBtnId?: string;
    ariaLabel?: string;
    dataCopy?: string;
    class?: string;
}

const { copyBtnId, ariaLabel = "Copy", dataCopy = "", class: className } = Astro.props;
---

<div class:list={["platform-code-block", className]}>
    <div class="code-header">
        <div class="platform-tabs" role="tablist" aria-label="Choose your shell">
            {platformOptions.map((p) => (
                <button
                    role="tab"
                    type="button"
                    data-platform-option={p.id}
                    aria-selected={p.id === DEFAULT_PLATFORM ? "true" : "false"}
                    tabindex={p.id === DEFAULT_PLATFORM ? "0" : "-1"}
                    class="header-tab"
                >
                    {p.label}
                </button>
            ))}
        </div>
        <button type="button" class="copy-btn" id={copyBtnId} aria-label={ariaLabel} data-copy={dataCopy} set:html={COPY_SVG} />
    </div>
    <slot />
</div>

<script>
import '../scripts/copy-handler.js';
</script>

<style>
    .platform-code-block {
        position: relative;
        background: var(--code-bg);
        border: var(--border-w-default) solid var(--border-color);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .code-header {
        display: flex;
        align-items: stretch;
        justify-content: space-between;
        background: var(--bg-surface);
        border-radius: inherit;
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
        border-bottom: var(--border-w-default) solid var(--border-color);
    }

    .platform-tabs {
        display: flex;
        align-items: stretch;
    }

    .header-tab {
        padding: 0 var(--space-4);
        height: 36px;
        background: transparent;
        border: none;
        border-bottom: var(--border-w-strong) solid transparent;
        color: var(--text-tertiary);
        font-size: var(--text-xs);
        font-weight: 600;
        font-family: inherit;
        letter-spacing: 0.04em;
        cursor: pointer;
        transition: color 0.2s, border-color 0.2s;
    }

    .header-tab[aria-selected="true"] {
        color: var(--code-text);
        border-bottom-color: var(--primary);
    }

    .header-tab:hover {
        color: var(--text-secondary);
    }

    .copy-btn {
        width: 32px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: var(--radius-md);
        background: transparent;
        color: var(--text-tertiary);
        cursor: pointer;
        margin-right: var(--space-1);
        transition: color 0.2s, background 0.2s;
        padding: 0;
    }

    .copy-btn:hover {
        color: var(--text-secondary);
        background: var(--bg-muted);
    }

    .copy-btn.copied {
        color: var(--primary);
    }

    :global([data-theme="light"]) .platform-code-block {
        border-color: transparent;
    }

    :global([data-theme="light"]) .code-header {
        background: color-mix(in srgb, var(--code-text) 5%, var(--code-bg));
        border-bottom-color: color-mix(in srgb, var(--code-text) 6%, var(--code-bg));
    }

    :global([data-theme="light"]) .header-tab,
    :global([data-theme="light"]) .copy-btn {
        color: var(--code-muted);
    }

    :global([data-theme="light"]) .header-tab:hover,
    :global([data-theme="light"]) .copy-btn:hover {
        color: var(--code-text);
    }

    :global([data-theme="light"]) .copy-btn:hover {
        background: color-mix(in srgb, var(--code-text) 6%, transparent);
    }

    @media (prefers-color-scheme: light) {
        :global(:root:not([data-theme="dark"])) .platform-code-block {
            border-color: transparent;
        }

        :global(:root:not([data-theme="dark"])) .code-header {
            background: color-mix(in srgb, var(--code-text) 5%, var(--code-bg));
            border-bottom-color: color-mix(in srgb, var(--code-text) 6%, var(--code-bg));
        }

        :global(:root:not([data-theme="dark"])) .header-tab,
        :global(:root:not([data-theme="dark"])) .copy-btn {
            color: var(--code-muted);
        }

        :global(:root:not([data-theme="dark"])) .header-tab:hover,
        :global(:root:not([data-theme="dark"])) .copy-btn:hover {
            color: var(--code-text);
        }

        :global(:root:not([data-theme="dark"])) .copy-btn:hover {
            background: color-mix(in srgb, var(--code-text) 6%, transparent);
        }
    }

    .copy-btn :global(svg) {
        width: 18px;
        height: 18px;
    }

    .platform-code-block :global(pre) {
        margin: 0;
        padding: var(--space-4) var(--space-5);
        overflow-x: auto;
        background: transparent;
        border-radius: 0;
    }

    .platform-code-block :global(code) {
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        color: var(--code-text);
        line-height: 1.6;
        white-space: pre;
        background: transparent;
    }

    @media (max-width: 768px) {
        .platform-code-block :global(pre) {
            padding: var(--space-3) var(--space-4);
        }

        .platform-code-block :global(code) {
            font-size: 12px;
        }
    }
</style>
