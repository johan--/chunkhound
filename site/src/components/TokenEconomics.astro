<section class="token-economics">
    <div class="container">
        <p class="eyebrow">TOKEN EFFICIENCY</p>
        <h2 class="heading">
            A retry is just a token you didn't have to spend.
        </h2>
        <p class="body">
            When an agent doesn't know your architecture, it guesses. When it
            guesses wrong, it loops — regenerating on context already polluted
            by the failed attempt. ChunkHound spends tokens once: a research
            call that surfaces the auth chain, the utility that already exists,
            the data model that changed last quarter. Users consistently report
            the same pattern across codebases of every size.
        </p>

        <div class="contrast-card">
            <div class="contrast-grid">
                <div class="col col-blind">
                    <p class="col-label">Without context</p>
                    <div class="flow-step dim">Attempt 1 — wrong direction</div>
                    <div class="flow-step dim">
                        Attempt 2 — missed existing utility
                    </div>
                    <div class="flow-step dim">
                        Attempt 3 — architecture conflict
                    </div>
                    <div class="flow-step dim">
                        Debug loop, backtrack, re-query
                    </div>
                    <div class="flow-step done-bad">Attempt 4 — done.</div>
                </div>
                <div class="col-divider"></div>
                <div class="col col-grounded">
                    <p class="col-label">With ChunkHound</p>
                    <div class="flow-step">
                        Research call — architecture mapped,
                    </div>
                    <div class="flow-step cursor-host">utilities found, patterns understood.</div>
                    <div class="flow-step">&nbsp;</div>
                    <div class="flow-step">&nbsp;</div>
                    <div class="flow-step done-good">Attempt 1 — done.</div>
                </div>
            </div>
        </div>

        <blockquote class="token-quote">
            &ldquo;I would pay for ChunkHound. The code research is that good.&rdquo;
            <cite>— @FlatTreNeb, Reddit</cite>
        </blockquote>

    </div>
</section>

<script>
  import { setupScrollAnimation } from "../scripts/scroll-observer.ts";
  setupScrollAnimation(".token-economics");
</script>

<style>
    /* ---- Layout ---- */
    .token-economics {
        padding: var(--space-10) 0;
        text-align: center;
    }

    .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 var(--space-6);
    }

    /* ---- Text ---- */
    .eyebrow {
        text-transform: uppercase;
        font-size: var(--text-xs);
        line-height: var(--lh-xs);
        font-weight: 600;
        letter-spacing: 0.12em;
        color: var(--text-tertiary);
        margin-bottom: var(--space-3);
    }

    .heading {
        font-size: var(--text-2xl);
        line-height: var(--lh-2xl);
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: var(--space-4);
    }

    .body {
        font-size: var(--text-base);
        line-height: var(--lh-base);
        color: var(--text-secondary);
        max-width: 720px;
        margin: 0 auto var(--space-7);
    }

    /* ---- Contrast card — same dark surface as Hero terminal card ---- */
    .contrast-card {
        background: var(--code-bg);
        border-radius: var(--radius-xl);
        padding: var(--space-6);
        max-width: 720px;
        margin: 0 auto var(--space-7);
        text-align: left;
    }

    .contrast-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: var(--space-5);
        align-items: start;
    }

    .col-divider {
        width: 1px;
        background: var(--border-color);
        align-self: stretch;
    }

    .col-label {
        font-family: "JetBrains Mono", monospace;
        font-size: var(--text-xs);
        line-height: var(--lh-xs);
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        margin-bottom: var(--space-3);
    }

    .flow-step {
        font-family: "JetBrains Mono", monospace;
        font-size: var(--text-sm);
        line-height: var(--lh-sm);
        color: var(--code-text);
        padding: var(--space-2) 0;
        border-bottom: 1px solid var(--border-subtle);
    }

    .flow-step.dim {
        color: var(--text-muted);
    }

    .flow-step.done-bad {
        color: var(--text-secondary);
        font-weight: 600;
        border-bottom: none;
    }

    .flow-step.done-good {
        color: var(--primary);
        font-weight: 600;
        border-bottom: none;
    }

    /* Mobile: stack columns vertically */
    @media (max-width: 600px) {
        .contrast-grid {
            grid-template-columns: 1fr;
        }
        .col-divider {
            width: 100%;
            height: 1px;
            align-self: auto;
        }
    }

    /* ============================================================
       SCROLL ANIMATIONS
       Progressive enhancement — requires .js-animate on section.
    ============================================================ */

    /* --- Initial hidden states (set by JS adding .js-animate) --- */

    .js-animate .eyebrow,
    .js-animate .heading,
    .js-animate .body {
        opacity: 0;
        transform: translateY(18px);
        transition:
            opacity 0.55s ease,
            transform 0.55s ease;
    }

    .js-animate .contrast-card {
        opacity: 0;
        transform: translateY(14px);
        transition:
            opacity 0.5s ease 0.35s,
            transform 0.5s ease 0.35s;
    }

    .js-animate .col-divider {
        transform-origin: top;
        transform: scaleY(0);
        transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1) 1.1s;
    }

    @media (max-width: 600px) {
        .js-animate .col-divider {
            transform-origin: left;
            transform: scaleX(0);
        }
        .is-visible .col-divider {
            transform: scaleX(1) !important;
        }
    }

    .js-animate .col-blind > *,
    .js-animate .col-grounded > * {
        opacity: 0;
    }

    /* --- Revealed states --- */

    .is-visible .eyebrow {
        opacity: 1;
        transform: none;
        transition-delay: 0s;
    }
    .is-visible .heading {
        opacity: 1;
        transform: none;
        transition-delay: 0.1s;
    }
    .is-visible .body {
        opacity: 1;
        transform: none;
        transition-delay: 0.2s;
    }

    .is-visible .contrast-card {
        opacity: 1;
        transform: none;
    }

    .is-visible .col-divider {
        transform: scaleY(1);
    }

    /* --- Keyframes --- */

    @keyframes stepReveal {
        from {
            opacity: 0;
            transform: translateY(7px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Fade in, then shake — communicates frustration */
    @keyframes shakeReveal {
        0% {
            opacity: 0;
            transform: translateY(7px);
        }
        22% {
            opacity: 1;
            transform: translateY(0);
        }
        38% {
            transform: translateX(-5px);
        }
        54% {
            transform: translateX(5px);
        }
        68% {
            transform: translateX(-4px);
        }
        82% {
            transform: translateX(3px);
        }
        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Spring-style pop — feels satisfying, not just "done" */
    @keyframes popReveal {
        0% {
            opacity: 0;
            transform: scale(0.86);
        }
        55% {
            opacity: 1;
            transform: scale(1.06);
        }
        100% {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* Subtle glow pulse to celebrate the result */
    @keyframes glowPulse {
        0%,
        100% {
            text-shadow: none;
        }
        50% {
            text-shadow: 0 0 18px var(--primary);
        }
    }

    /* Terminal cursor blink */
    @keyframes cursorBlink {
        0%,
        100% {
            opacity: 0;
        }
        50% {
            opacity: 1;
        }
    }

    /* --- Left column: the failure story unfolds step by step --- */

    .is-visible .col-blind > *:nth-child(1) {
        animation: stepReveal 0.35s ease 0.7s both;
    }
    .is-visible .col-blind > *:nth-child(2) {
        animation: stepReveal 0.35s ease 0.85s both;
    }
    .is-visible .col-blind > *:nth-child(3) {
        animation: stepReveal 0.35s ease 1.0s both;
    }
    .is-visible .col-blind > *:nth-child(4) {
        animation: stepReveal 0.35s ease 1.15s both;
    }
    .is-visible .col-blind > *:nth-child(5) {
        animation: stepReveal 0.35s ease 1.3s both;
    }
    /* "Attempt 4 — done." reveals then shakes with frustration */
    .is-visible .col-blind > *:nth-child(6) {
        animation: shakeReveal 0.75s ease 1.45s both;
    }

    /* --- Right column: the clean solution, starting after failure plays out --- */

    .is-visible .col-grounded > *:nth-child(1) {
        animation: stepReveal 0.35s ease 1.9s both;
    }
    .is-visible .col-grounded > *:nth-child(2) {
        animation: stepReveal 0.35s ease 2.05s both;
    }
    /* "utilities found" line gets a terminal cursor after it appears */
    .is-visible .col-grounded > *:nth-child(3) {
        animation: stepReveal 0.35s ease 2.2s both;
    }
    .is-visible .col-grounded > *:nth-child(4) {
        animation: stepReveal 0.25s ease 2.45s both;
    }
    .is-visible .col-grounded > *:nth-child(5) {
        animation: stepReveal 0.25s ease 2.7s both;
    }
    /* "Attempt 1 — done." springs in, then glows */
    .is-visible .col-grounded > *:nth-child(6) {
        animation:
            popReveal 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 3.0s both,
            glowPulse 1.1s ease-in-out 3.7s 1;
    }

    /* Terminal cursor: appears inline at end of "utilities found" line */
    .cursor-host::after {
        content: "█";
        font-size: 0.7em;
        margin-left: 2px;
        opacity: 0;
    }
    .is-visible .cursor-host::after {
        animation: cursorBlink 0.55s step-end 5 2.5s;
    }

    /* ---- Accessibility: respect reduced-motion preference ---- */
    @media (prefers-reduced-motion: reduce) {
        .js-animate .eyebrow,
        .js-animate .heading,
        .js-animate .body,
        .js-animate .contrast-card {
            opacity: 1;
            transform: none;
            transition: none;
        }
        .js-animate .col-blind > *,
        .js-animate .col-grounded > * {
            opacity: 1;
            animation: none !important;
        }
        .js-animate .col-divider {
            transform: scaleY(1);
            transition: none;
        }
        .cursor-host::after {
            display: none;
        }
    }

    .token-quote {
        margin: var(--space-8) auto 0;
        max-width: 560px;
        padding: 0 var(--space-4);
        text-align: center;
        font-size: var(--text-sm);
        line-height: var(--lh-sm);
        font-weight: 400;
        color: var(--text-secondary);
        font-style: italic;
    }

    .token-quote::before {
        content: "\201C";
        display: block;
        font-size: 3rem;
        line-height: 1;
        font-weight: 700;
        font-style: normal;
        color: var(--primary);
        margin-bottom: var(--space-2);
    }

    .token-quote cite {
        display: block;
        margin-top: var(--space-2);
        font-style: normal;
        font-weight: 600;
        font-size: var(--text-xs);
        letter-spacing: 0.04em;
        color: var(--text-tertiary);
    }
</style>
