---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const guides = [
  { icon: 'ph-rocket-launch', title: 'Getting Started', href: '/docs/getting-started/' },
  { icon: 'ph-sliders-horizontal', title: 'Configuration', href: '/docs/configuration/' },
  { icon: 'ph-terminal-window', title: 'CLI Reference', href: '/docs/cli-reference/' },
  { icon: 'ph-clock-counter-clockwise', title: 'Changelog', href: '/docs/changelog/' },
  { icon: 'ph-git-pull-request', title: 'Contributing', href: '/docs/contributing/' },
];

function isActive(href: string): boolean {
  const a = currentPath.replace(/\/+$/, '');
  const b = href.replace(/\/+$/, '');
  return a === b;
}
---

<aside class="docs-sidebar" id="docs-sidebar" aria-label="Documentation navigation">
  <div class="sidebar-inner">
    <label class="sr-only" for="docs-nav-filter">Filter pages</label>
    <input
      id="docs-nav-filter"
      class="sidebar-filter"
      type="search"
      placeholder="Filter pages"
      autocomplete="off"
      data-docs-nav-filter
    />

    <div class="sidebar-section" data-sidebar-section>
      <div class="sidebar-section-title">Guides</div>
      <nav aria-label="Documentation guides">
        {guides.map((g) => {
          const Icon = g.icon;
          return (
            <a
              href={g.href}
              class:list={['sidebar-link', { active: isActive(g.href) }]}
              data-sidebar-link
            >
              <Icon size="16" weight="duotone" aria-hidden="true" />
              <span>{g.title}</span>
            </a>
          );
        })}
      </nav>
    </div>
  </div>
</aside>

<script>
  import "@phosphor-icons/webcomponents/PhClockCounterClockwise";
  import "@phosphor-icons/webcomponents/PhGitPullRequest";
  import "@phosphor-icons/webcomponents/PhRocketLaunch";
  import "@phosphor-icons/webcomponents/PhSlidersHorizontal";
  import "@phosphor-icons/webcomponents/PhTerminalWindow";
</script>
